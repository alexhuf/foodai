FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends bash ca-certificates tini \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/foodai

COPY requirements-codex-temporal.txt /tmp/requirements-codex-temporal.txt
RUN python -m pip install --upgrade pip setuptools wheel \
    && python -m pip install -r /tmp/requirements-codex-temporal.txt

COPY scripts/start_codex.sh /usr/local/bin/start_codex.sh
RUN chmod +x /usr/local/bin/start_codex.sh

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/start_codex.sh"]
CMD ["bash"]
